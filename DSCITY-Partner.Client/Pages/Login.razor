@page "/login"
@layout DSCITYPartner.Client.Layout.AuthLayout
@implements IDisposable
@inject NavigationManager Navigation
@inject AccountDirectory Accounts
@inject PartnerAuthService Session
@inject LanguageService Loc

<PageTitle>@Loc.Text("Đăng nhập", "Sign in") — DSCITY Partner</PageTitle>

<div class="auth-shell">
    <section class="auth-visual">
        <div class="auth-brand-stack">
            <span class="auth-logo-badge">
                <img class="auth-logo" src="images/dscity-logo.png" alt="Logo DSCITY" />
            </span>
            <h1><span class="brand-ds">DS</span><span class="brand-city">CITY</span></h1>
            <p>@Loc.Text("Cổng đối tác — kết nối, vận hành, tăng trưởng.", "Partner portal — connect, operate, grow.")</p>
        </div>
        <div class="auth-skyline"></div>
    </section>

    <section class="auth-card">
        <div class="auth-card-top">
            <div class="language-switcher" role="group" aria-label="Language switcher">
                <button class="lang-button @(Loc.IsEnglish ? null : "active")" type="button" @onclick="() => SetLanguage(false)">VI</button>
                <button class="lang-button @(Loc.IsEnglish ? "active" : null)" type="button" @onclick="() => SetLanguage(true)">EN</button>
            </div>
        </div>

        <div class="auth-toggle">
            <button class="auth-tab @(isRegister ? null : "active")" type="button" @onclick="() => SwitchMode(false)">@Loc.Text("Đăng nhập", "Sign in")</button>
            <button class="auth-tab @(isRegister ? "active" : null)" type="button" @onclick="() => SwitchMode(true)">@Loc.Text("Đăng ký", "Register")</button>
        </div>

        <div class="auth-copy">
            <p class="eyebrow">@Loc.Text("Chào mừng đến với DSCITY", "Welcome to DSCITY")</p>
            <h2>@Loc.Text(isRegister ? "Tạo tài khoản đối tác" : "Đăng nhập để tiếp tục", isRegister ? "Create a partner account" : "Sign in to continue")</h2>
            <p>@Loc.Text("Chỉ đối tác có tài khoản mới có thể truy cập cổng đối tác.", "Only partners with an account can access the partner portal.")</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(feedbackMessage))
        {
            <div class="feedback-banner">@feedbackMessage</div>
        }

        <div class="field-stack auth-form">
            @if (isRegister)
            {
                <label class="field-group"><span>@Loc.Text("Họ và tên", "Full name")</span><input @bind="registerFullName" /></label>
            }
            <label class="field-group"><span>@Loc.Text("Số điện thoại", "Phone number")</span><input @bind="phone" /></label>
            <label class="field-group"><span>@Loc.Text("Mật khẩu", "Password")</span><input type="password" @bind="password" /></label>
            @if (isRegister)
            {
                <label class="field-group"><span>@Loc.Text("Xác nhận mật khẩu", "Confirm password")</span><input type="password" @bind="confirmPassword" /></label>
            }

            <button class="btn btn-hero-primary auth-submit" type="button" @onclick="SubmitAsync">
                @Loc.Text(isRegister ? "Tạo tài khoản" : "Đăng nhập", isRegister ? "Create account" : "Sign in")
            </button>

            <div class="auth-divider"><span>@Loc.Text("hoặc", "or")</span></div>

            <button class="btn btn-auth-secondary" type="button">@Loc.Text("Đăng nhập với Google", "Continue with Google")</button>
            <button class="btn btn-auth-secondary" type="button">@Loc.Text("Đăng nhập với Apple", "Continue with Apple")</button>
        </div>

        <p class="auth-footnote">
            @Loc.Text(isRegister ? "Đã có tài khoản?" : "Chưa có tài khoản?", isRegister ? "Already have an account?" : "No account yet?")
            <button class="link-button" type="button" @onclick="ToggleMode">@Loc.Text(isRegister ? "Đăng nhập" : "Đăng ký ngay", isRegister ? "Sign in" : "Register now")</button>
        </p>

        <p class="auth-hint">@Loc.Text("Tài khoản mẫu: 0123456789 / 123456", "Demo account: 0123456789 / 123456")</p>
    </section>
</div>

@code {
    private bool isRegister;
    private string phone = string.Empty;
    private string password = string.Empty;
    private string confirmPassword = string.Empty;
    private string registerFullName = string.Empty;
    private string? feedbackMessage;

    protected override void OnInitialized()
    {
        Loc.OnChange += HandleLanguageChanged;
        Session.OnChange += HandleSessionChanged;
    }

    private void SetLanguage(bool isEnglish) => Loc.SetEnglish(isEnglish);

    private void SwitchMode(bool register)
    {
        isRegister = register;
        feedbackMessage = null;
        password = string.Empty;
        confirmPassword = string.Empty;
    }

    private void ToggleMode() => SwitchMode(!isRegister);

    private Task SubmitAsync()
    {
        if (isRegister)
        {
            return RegisterAsync();
        }

        return LoginAsync();
    }

    private Task LoginAsync()
    {
        if (!Accounts.ValidateCredentials(phone, password, out var user) || user is null)
        {
            feedbackMessage = Loc.Text("Sai số điện thoại hoặc mật khẩu.", "Incorrect phone number or password.");
            return Task.CompletedTask;
        }

        Session.SignIn(user);
        Navigation.NavigateTo("/", replace: true);
        return Task.CompletedTask;
    }

    private Task RegisterAsync()
    {
        if (string.IsNullOrWhiteSpace(registerFullName) || string.IsNullOrWhiteSpace(phone) || string.IsNullOrWhiteSpace(password))
        {
            feedbackMessage = Loc.Text("Vui lòng nhập đầy đủ thông tin.", "Please fill in all required fields.");
            return Task.CompletedTask;
        }

        if (password != confirmPassword)
        {
            feedbackMessage = Loc.Text("Mật khẩu xác nhận không khớp.", "Password confirmation does not match.");
            return Task.CompletedTask;
        }

        if (!Accounts.Register(registerFullName, phone, password, out var error))
        {
            feedbackMessage = Loc.IsEnglish switch
            {
                true when error == "Số điện thoại đã tồn tại." => "This phone number already exists.",
                _ => error
            };
            return Task.CompletedTask;
        }

        Accounts.ValidateCredentials(phone, password, out var user);
        if (user is not null)
        {
            Session.SignIn(user);
        }

        Navigation.NavigateTo("/", replace: true);
        return Task.CompletedTask;
    }

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);
    private void HandleSessionChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Loc.OnChange -= HandleLanguageChanged;
        Session.OnChange -= HandleSessionChanged;
    }
}
