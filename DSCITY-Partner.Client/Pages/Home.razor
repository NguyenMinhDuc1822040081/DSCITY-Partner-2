@page "/"
@implements IDisposable
@inject PartnerPortalService Portal
@inject PartnerAuthService Auth
@inject LanguageService Loc
@inject NavigationManager Navigation

<PageTitle>@Loc.Text("Cổng đối tác DSCITY", "DSCITY Partner Portal")</PageTitle>

<div class="content dashboard-shell">

    <section class="hero-panel">
        <div class="hero-toolbar">
            <div class="language-switcher" role="group" aria-label="Language switcher">
                <button class="lang-button @(Loc.IsEnglish ? null : "active")" type="button" @onclick="() => SetLanguage(false)">VI</button>
                <button class="lang-button @(Loc.IsEnglish ? "active" : null)" type="button" @onclick="() => SetLanguage(true)">EN</button>
            </div>
            <button class="hero-logout" type="button" @onclick="Logout">@Loc.Text("Đăng xuất", "Sign out")</button>
        </div>
        <div>
            <div class="brand-lockup">
                <span class="brand-logo-badge">
                    <img class="brand-logo" src="images/dscity-logo.png" alt="Logo DSCITY" />
                </span>
                <p class="brand-name"><span class="brand-ds">DS</span><span class="brand-city">CITY</span></p>
            </div>
            <h1>@Loc.Text("Cổng đối tác DSCITY", "DSCITY Partner Portal")</h1>
            <p class="hero-copy">
                @Loc.Text(
                    "Theo dõi đơn hàng, doanh thu và trạng thái hợp tác của bạn ở một nơi.",
                    "Track your orders, revenue, and partnership status all in one place.")
                @Loc.Text("Trạng thái phiên:", "Session status:")
                <strong>@(Auth.IsAuthenticated
                    ? Loc.Text($"Đã đăng nhập — {Auth.CurrentUser!.FullName}", $"Signed in — {Auth.CurrentUser!.FullName}")
                    : Loc.Text("Khách (chưa đăng nhập)", "Guest (not signed in)"))</strong>.
            </p>
        </div>
        <div class="hero-highlight">
            <small>@Loc.Text("Đối tác đang hoạt động", "Active partners")</small>
            <strong>@Portal.GetPartners().Count</strong>
            <span>@Loc.Text("Cập nhật theo thời gian thực", "Updated in real time")</span>
        </div>
    </section>

    <section class="kpi-grid">
        <div class="kpi-card">
            <span class="kpi-label">@Loc.Text("Tổng đối tác", "Total partners")</span>
            <strong>@Portal.GetPartners().Count</strong>
        </div>
        <div class="kpi-card accent-card">
            <span class="kpi-label">@Loc.Text("Đơn chờ duyệt", "Orders pending approval")</span>
            <strong>3</strong>
        </div>
        <div class="kpi-card">
            <span class="kpi-label">@Loc.Text("Doanh thu tháng", "Monthly revenue")</span>
            <strong>₫ 128.5M</strong>
        </div>
        <div class="kpi-card">
            <span class="kpi-label">@Loc.Text("Tỷ lệ duyệt", "Approval rate")</span>
            <strong>92%</strong>
        </div>
    </section>

    <section class="panel-card">
        <div class="section-heading">
            <div>
                <span class="section-kicker">@Loc.Text("Danh sách", "List")</span>
                <h2>@Loc.Text("Đối tác", "Partners")</h2>
            </div>
            <div class="action-row">
                <input class="auth-input" style="max-width:240px" @bind="_newPartner" placeholder="@Loc.Text("Tên đối tác mới", "New partner name")" />
                <button class="action-btn approve" @onclick="Add">@Loc.Text("Thêm", "Add")</button>
            </div>
        </div>

        <div class="table-shell">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@Loc.Text("Tên đối tác", "Partner name")</th>
                        <th>@Loc.Text("Trạng thái", "Status")</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var i = 1;
                    }
                    @foreach (var p in Portal.GetPartners())
                    {
                        <tr>
                            <td>@i</td>
                            <td><strong>@p</strong><span>@Loc.Text("Mã", "Code") DSC-@(1000 + i)</span></td>
                            <td>
                                <span class="status-badge @(i % 3 == 0 ? "status-pending" : "status-approved")">
                                    @Loc.Translate(i % 3 == 0 ? "Chờ duyệt" : "Đã duyệt")
                                </span>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>
    </section>

</div>

@code {
    private string _newPartner = string.Empty;

    protected override void OnInitialized()
    {
        Loc.OnChange += HandleStateChanged;
        Auth.OnChange += HandleStateChanged;
    }

    private void SetLanguage(bool isEnglish) => Loc.SetEnglish(isEnglish);

    private void Logout()
    {
        Auth.SignOut();
        Navigation.NavigateTo("/login", replace: true);
    }

    private void Add()
    {
        Portal.AddPartner(_newPartner);
        _newPartner = string.Empty;
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Loc.OnChange -= HandleStateChanged;
        Auth.OnChange -= HandleStateChanged;
    }
}
